# ======= 1. 移动版 RAX3000m 身份锁定 =======
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_cmcc_rax3000m=y

# ======= 2. 编译环境饱和设置 (防止依赖项被精简) =======
# 开启此项会编译所有内核模块，确保“老固件”中的各种小众驱动都有源码基础
CONFIG_ALL_KMODS=y
# 允许编译非共享包，增加配置的显式可见度
CONFIG_ALL_NONSHARED=y

# ======= 3. 内核与指令集基础 (复刻自老固件底层) =======
# 针对 Cortex-A53 的硬件补丁与 BPF 指令集支持
CONFIG_HAS_BPF_TOOLCHAIN=y
CONFIG_PACKAGE_kmod-crypto-core=y
CONFIG_PACKAGE_kmod-crypto-hash=y
CONFIG_PACKAGE_kmod-crypto-manager=y
CONFIG_PACKAGE_kmod-crypto-ecb=y
CONFIG_PACKAGE_kmod-crypto-cbc=y
CONFIG_PACKAGE_kmod-crypto-crc32c=y
CONFIG_PACKAGE_kmod-crypto-authenc=y

# ======= 4. NAND 闪存与分区管理 (针对 128MB NAND 核心) =======
# 确保系统识别 NAND 闪存并生成正确的分区挂载
CONFIG_PACKAGE_kmod-mtd-rw=y
CONFIG_PACKAGE_kmod-ubi=y
CONFIG_PACKAGE_kmod-ubifs=y
CONFIG_PACKAGE_kmod-lib-lzo=y
CONFIG_PACKAGE_kmod-lib-zlib-deflate=y
CONFIG_PACKAGE_kmod-lib-zlib-inflate=y

# ======= 2. USB 核心与物理层 (饱和复刻，解决识别与供电) =======
CONFIG_PACKAGE_libusb-1.0-0=y
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y

# MTK 平台专属物理层控制器 (移动版 RAX3000m 专用)
CONFIG_PACKAGE_kmod-mtk-tphy=y
CONFIG_PACKAGE_kmod-usb-dwc3=y
CONFIG_PACKAGE_kmod-usb-mtu3=y
CONFIG_PACKAGE_kmod-usb-xhci-mtk=y

# 链路层底层校验与协议库 (全量复刻老固件基因)
CONFIG_PACKAGE_kmod-lib-crc-ccitt=y
CONFIG_PACKAGE_kmod-lib-crc16=y
CONFIG_PACKAGE_kmod-lib-crc32c=y
CONFIG_PACKAGE_kmod-mii=y
CONFIG_PACKAGE_kmod-libphy=y

# 存储核心与模式切换依赖 (移远模块切换 NCM 模式必备底层)
CONFIG_PACKAGE_kmod-scsi-core=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y

# 核心字符集补全 (老固件基因，确保内核不报 NLS 错误)
CONFIG_PACKAGE_kmod-nls-base=y
CONFIG_PACKAGE_kmod-nls-utf8=y
CONFIG_PACKAGE_kmod-nls-cp437=y
CONFIG_PACKAGE_kmod-nls-iso8859-1=y

# ======= 强制剔除主题干扰 (响应你的要求) =======
# 明确不选择 Argon，强制回归 OpenWrt 默认主题
# CONFIG_PACKAGE_luci-theme-argon is not set
# CONFIG_PACKAGE_luci-app-argon-config is not set
CONFIG_PACKAGE_luci-theme-bootstrap=y

# ======= 3. 5G 模组核心内核驱动 (确保 eth2 生成) =======
# MHI 总线驱动 (移远 5G 模块走 PCIe/MHI 通道的关键，老固件必选)
CONFIG_PACKAGE_kmod-pcie-mhi=y

# USB 网络协议族 (全量覆盖，防止协议不匹配)
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-huawei-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-net-cdc-subset=y

# 串口与控制通道 (用于发送 AT 指令与获取信号强度)
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-wwan=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-serial-qualcomm=y

# ======= 4. 拨号工具与 GUI 协议插件 (饱和复刻) =======
# 核心拨号工具 (锁定老固件同款 quectel-cm)
CONFIG_PACKAGE_quectel-cm-5G=y

# 拨号底层库与脚本
CONFIG_PACKAGE_chat=y
CONFIG_PACKAGE_comgt=y
CONFIG_PACKAGE_comgt-ncm=y
CONFIG_PACKAGE_uqmi=y
CONFIG_PACKAGE_umbim=y

# Luci 界面协议支持 (确保在网络设置里能看到 NCM/QMI 选项)
CONFIG_PACKAGE_luci-proto-3g=y
CONFIG_PACKAGE_luci-proto-ncm=y
CONFIG_PACKAGE_luci-proto-qmi=y
CONFIG_PACKAGE_luci-proto-mbim=y
CONFIG_PACKAGE_luci-proto-modemmanager=n

# 5G 辅助工具 (复刻自老固件)
CONFIG_PACKAGE_sms-tool=y
CONFIG_PACKAGE_luci-app-modem=y

# ======= 5. 冲突规避 (强制排除 ModemManager) =======
# 坚决不安装 ModemManager，防止其抢占 quectel-cm 的端口
# CONFIG_PACKAGE_modemmanager is not set
# CONFIG_PACKAGE_luci-app-modemmanager is not set

# ======= 4. WiFi 6 (MT7981) 驱动与硬件加速 =======
CONFIG_PACKAGE_kmod-mt76=y
CONFIG_PACKAGE_kmod-mt76-connac=y
CONFIG_PACKAGE_kmod-mt76-core=y
CONFIG_PACKAGE_kmod-mt7915e=y
CONFIG_PACKAGE_kmod-mt7981-firmware=y
CONFIG_PACKAGE_wpad-openssl=y

# MT7981 专用 WiFi 硬件加速 (提升无线吞吐，降低 CPU 占用)
CONFIG_PACKAGE_kmod-mt76-ddma=y

# ======= 5. 硬件加解密引擎 (RAX3000m 性能核心) =======
# 锁定 EIP-197 硬件加速引擎，这是 OpenClash 跑满速的关键
CONFIG_PACKAGE_kmod-crypto-hw-safexcel=y
CONFIG_PACKAGE_eip197-mini-firmware=y

# 补全硬件加密相关的底层库 (饱和复刻老固件)
CONFIG_PACKAGE_kmod-crypto-authenc=y
CONFIG_PACKAGE_kmod-crypto-chacha20poly1305=y
CONFIG_PACKAGE_kmod-crypto-lib-chacha20=y
CONFIG_PACKAGE_kmod-crypto-lib-poly1305=y
CONFIG_PACKAGE_kmod-crypto-lib-curve25519=y

# ======= 6. 系统性能优化组件 (老固件基因) =======
# 中断均衡与熵池优化 (防止高负载下系统卡死)
CONFIG_PACKAGE_irqbalance=y
CONFIG_PACKAGE_luci-app-irqbalance=y
CONFIG_PACKAGE_haveged=y

# 网络加速核心 (BBR 与硬件流量分载)
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_BBR_CCA=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_OFFLOADING=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_SHORTCUT_FE=y

# ======= 7. DNS 核心处理 (解决 OpenClash 冲突的关键) =======
# 必须显式禁用普通版 dnsmasq
# CONFIG_PACKAGE_dnsmasq is not set
# 强制安装全功能版 dnsmasq-full
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y
CONFIG_PACKAGE_dnsmasq_full_ipset=y
CONFIG_PACKAGE_dnsmasq_full_nftset=y

# ======= 8. 核心网络插件 (饱和复刻) =======
# OpenClash 及其依赖环境
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_libopenssl=y

# SmartDNS
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_smartdns=y

# 系统基础实用插件 (复刻自老固件)
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-app-access-control=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-app-zerotier=y

# ======= 9. 界面与语言支持 (纯正中文环境) =======
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-openclash-zh-cn=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y
CONFIG_PACKAGE_luci-i18n-turboacc-zh-cn=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y

# ======= 10. 深度调试与诊断工具 (备战终端指令) =======
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_pciutils=y
CONFIG_PACKAGE_ethtool=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_lsof=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_terminfo=y
CONFIG_PACKAGE_screen=y
CONFIG_PACKAGE_iperf3=y

# 网络连通性增强工具 (老固件基因)
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_openssh-sftp-server=y

# ======= 11. 强制清理与排除项 (彻底扫除干扰) =======
# 坚决杀掉 Argon 主题及其配置界面
# CONFIG_PACKAGE_luci-theme-argon is not set
# CONFIG_PACKAGE_luci-app-argon-config is not set

# 坚决杀掉 ModemManager (防止 5G 模块端口被占)
# CONFIG_PACKAGE_modemmanager is not set
# CONFIG_PACKAGE_luci-app-modemmanager is not set

# 杀掉可能预装的其他代理软件 (确保 OpenClash 唯一性)
# CONFIG_PACKAGE_luci-app-ssr-plus is not set
# CONFIG_PACKAGE_luci-app-v2ray-server is not set

# ======= 12. 移动版 RAX3000m 特殊生成配置 =======
# 确保强制生成适合 128MB NAND 的 .bin 格式固件
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_SQUASHFS_BLOCK_SIZE=256
CONFIG_TARGET_UBIFS_FREE_SPACE_FIXUP=y
