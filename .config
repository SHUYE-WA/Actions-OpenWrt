# ======= 1. 硬件平台定义 (RAX3000M 核心) =======
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_xiaomi_rax3000m=y

# 允许编译独立软件包 (复刻老固件的灵活性，确保依赖包不被自动剔除)
CONFIG_ALL_NONSHARED=y
CONFIG_ALL_KMODS=y

# 基础系统架构补丁 (对应老固件底层，确保内核加密框架完整)
CONFIG_HAS_BPF_TOOLCHAIN=y
CONFIG_PACKAGE_kmod-crypto-core=y
CONFIG_PACKAGE_kmod-crypto-hash=y
CONFIG_PACKAGE_kmod-crypto-manager=y
CONFIG_PACKAGE_kmod-crypto-ecb=y
CONFIG_PACKAGE_kmod-crypto-cbc=y

# ======= 2. USB 核心与物理层 (彻底解决 -99 识别故障) =======
CONFIG_PACKAGE_libusb-1.0-0=y
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y

# MTK 平台专用物理层控制器 (RAX3000M 硬件点火关键)
CONFIG_PACKAGE_kmod-mtk-tphy=y
CONFIG_PACKAGE_kmod-usb-dwc3=y
CONFIG_PACKAGE_kmod-usb-mtu3=y
CONFIG_PACKAGE_kmod-usb-xhci-mtk=y

# 链路层底层校验库 (老固件基因，缺失会导致网卡能识别但无法传数据)
CONFIG_PACKAGE_kmod-lib-crc-ccitt=y
CONFIG_PACKAGE_kmod-lib-crc16=y
CONFIG_PACKAGE_kmod-lib-crc32c=y
CONFIG_PACKAGE_kmod-mii=y
CONFIG_PACKAGE_kmod-libphy=y

# 存储与模式切换依赖 (虽然不需要打印，但某些 5G 模块在切换 NCM 模式时需要这些底层包)
CONFIG_PACKAGE_kmod-scsi-core=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y

# 字符集补全 (防止内核日志报 NLS 错误，确保系统稳定性)
CONFIG_PACKAGE_kmod-nls-base=y
CONFIG_PACKAGE_kmod-nls-utf8=y
CONFIG_PACKAGE_kmod-nls-cp437=y
CONFIG_PACKAGE_kmod-nls-iso8859-1=y
# ======= 3. 5G 模组核心驱动 (克隆老固件 5G 基因) =======

# MHI 总线驱动 (移远/广和通 5G 模组走 PCIe 模式的关键)
CONFIG_PACKAGE_kmod-pcie-mhi=y

# USB 网络协议栈 - NCM 家族 (生成 eth2 的核心驱动)
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-huawei-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y

# USB 网络协议栈 - QMI/MBIM 家族 (备选拨号协议)
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y

# USB 串口转换 (用于 AT 指令通信与模块状态监控)
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-serial-wwan=y
CONFIG_PACKAGE_kmod-usb-serial-qualcomm=y

# 核心拨号工具 (使用老固件同款 quectel-cm)
CONFIG_PACKAGE_quectel-cm-5G=y
CONFIG_PACKAGE_comgt=y
CONFIG_PACKAGE_comgt-ncm=y
CONFIG_PACKAGE_uqmi=y
CONFIG_PACKAGE_umbim=y

# LuCI 界面协议支持 (确保在 web 界面能看到并配置拨号)
CONFIG_PACKAGE_luci-proto-ncm=y
CONFIG_PACKAGE_luci-proto-quectel=y
CONFIG_PACKAGE_luci-proto-qmi=y
CONFIG_PACKAGE_luci-proto-mbim=y
CONFIG_PACKAGE_luci-proto-3g=y

# 短信与调试辅助
CONFIG_PACKAGE_sms-tool=y
CONFIG_PACKAGE_luci-app-modem=y

# ======= 4. 无线 WiFi 驱动 (RAX3000M 专用 MT76 家族) =======
CONFIG_PACKAGE_kmod-mt76=y
CONFIG_PACKAGE_kmod-mt76-connac=y
CONFIG_PACKAGE_kmod-mt76-core=y
CONFIG_PACKAGE_kmod-mt7915e=y
CONFIG_PACKAGE_kmod-mt7981-firmware=y

# WiFi 硬件加速 (RAX3000M 提升速率的关键，老固件必备)
CONFIG_PACKAGE_kmod-mt76-ddma=y

# WiFi 安全协议栈 (支持 WPA3，复刻老固件安全级别)
CONFIG_PACKAGE_wpad-openssl=y
CONFIG_PACKAGE_kmod-cfg80211=y
CONFIG_PACKAGE_kmod-mac80211=y

# ======= 4.1 硬件加解密引擎 (EIP-197 Safexcel) =======
# 这是 RAX3000M 的“大杀器”，极大降低 OpenClash 运行时的 CPU 负载
CONFIG_PACKAGE_kmod-crypto-hw-safexcel=y
CONFIG_PACKAGE_eip197-mini-firmware=y

# 核心加密协议库补全 (复刻老固件加密算法基因)
CONFIG_PACKAGE_kmod-crypto-authenc=y
CONFIG_PACKAGE_kmod-crypto-aead=y
CONFIG_PACKAGE_kmod-crypto-des=y
CONFIG_PACKAGE_kmod-crypto-md5=y
CONFIG_PACKAGE_kmod-crypto-hmac=y
CONFIG_PACKAGE_kmod-crypto-sha1=y
CONFIG_PACKAGE_kmod-crypto-sha256=y
CONFIG_PACKAGE_kmod-crypto-sha512=y

# ======= 4.2 内核网络加速 (BBR & TurboACC 基础) =======
# 确保网络高并发下的吞吐量
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_PACKAGE_kmod-ipt-conntrack-extra=y
CONFIG_PACKAGE_kmod-nf-conntrack-netlink=y


# ======= 5. 核心网络插件 (复刻老固件功能基因) =======

# 强制使用 dnsmasq-full (解决 OpenClash/SmartDNS 冲突的关键)
CONFIG_PACKAGE_dnsmasq=n
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y
CONFIG_PACKAGE_dnsmasq_full_ipset=y
CONFIG_PACKAGE_dnsmasq_full_nftset=y

# 透明代理与 DNS 加速核心
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-smartdns=y

# 网络加速组件 (TurboACC 及其核心算法)
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_BBR_CCA=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_OFFLOADING=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_SHORTCUT_FE=y

# 透明代理必备的内核隧道驱动 (确保流量正常重定向)
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-socket=y

# ======= 5.1 系统运行优化 (提高 5G 满速下的系统稳定性) =======

# CPU 中断均衡 (解决 5G 高并发流量导致的 CPU 单核负载过高)
CONFIG_PACKAGE_irqbalance=y
CONFIG_PACKAGE_luci-app-irqbalance=y

# 系统熵池优化 (防止系统因随机数不足导致的启动缓慢或插件卡死)
CONFIG_PACKAGE_haveged=y

# 远程终端与时间同步
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_ntpdate=y

# 基础依赖补全 (确保上述插件正常运行)
CONFIG_PACKAGE_libpthread=y
CONFIG_PACKAGE_librt=y
CONFIG_PACKAGE_zlib=y

# ======= 6. 界面语言包 (全中文支持) =======
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y
CONFIG_PACKAGE_luci-i18n-autocore-zh-cn=y
CONFIG_PACKAGE_luci-i18n-turboacc-zh-cn=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y

# ======= 6.1 5G 调试与网络排查工具 (老固件基因补全) =======
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_qmi-utils=y
CONFIG_PACKAGE_minicom=y
CONFIG_PACKAGE_picocom=y

# ======= 6.2 强制禁用项 (防止预装软件冲突 & 节省空间) =======

# 1. 彻底杀掉冲突的拨号管理器 (防止它抢占 5G 端口)
# CONFIG_PACKAGE_modemmanager is not set

# 2. 彻底杀掉普通版 DNS 服务 (防止与 OpenClash 冲突)
# CONFIG_PACKAGE_dnsmasq is not set

# 3. 彻底杀掉你不需要的预装代理 (如果源码自带了，强制不安装)
# CONFIG_PACKAGE_luci-app-ssr-plus is not set
# CONFIG_PACKAGE_luci-app-vssr is not set
# CONFIG_PACKAGE_luci-app-passwall is not set

# 4. 彻底杀掉冗余的主题 (只留默认或你自己选的)
# CONFIG_PACKAGE_luci-theme-bootstrap is not set
# CONFIG_PACKAGE_luci-theme-material is not set

# 5. 彻底杀掉老固件中确认冗余的打印机驱动
# CONFIG_PACKAGE_kmod-usb-printer is not set
# CONFIG_PACKAGE_luci-app-usb-printer is not set

# ======= 6.3 最后的稳定性补丁 =======
CONFIG_PACKAGE_autocore-arm=y
CONFIG_STAGING_DIR_HOST=y
